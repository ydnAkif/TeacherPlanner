# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User-specific
ServiceData/
*.xcuserstate
xcuserdata/

## Build results
build/
DerivedData/
*.hmap
*.ipa
*.subtype.tar.gz
*.xcresult

## Bundle
*.app
*.framework
*.xctest

## Dependency Manager
# CocoaPods
#
# We recommend against committing the Pods directory or your .xcworkspace
# if you use CocoaPods.
# Pods/

# Carthage
#
# We recommend against committing the Carthage/Build directory.
# Carthage/Build

# Swift Package Manager
#
# Add this line if you want to avoid committing the checkouts.
# .build/

## Fastlane
#
# It is recommended to not store the screenshots in the repo since they
# will clutter up the history.
# fastlane/screenshots

## Misc
.DS_Store
*.swp
*.lock
build.log
